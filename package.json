{
  "name": "bokebox",
  "version": "1.0.0",
  "private": true,
  "description": "BokeBox · AI 私人播客匣：视频转口播，人设与音色可自定义",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @bokebox/server dev",
    "dev:web": "pnpm --filter @bokebox/web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @bokebox/server start",
    "start:app": "./start.sh",
    "start:prod": "./start.sh prod",
    "docker:up": "./start.sh docker",
    "docker:down": "./start.sh docker:down",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:pull": "docker compose -f docker-compose.prod.yml pull"
  },
  "engines": {
    "node": ">=22.5"
  },
  "packageManager": "pnpm@9.15.0"
}
